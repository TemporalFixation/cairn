# ── Database ──────────────────────────────────────────────────
# Strong random string: openssl rand -base64 24
DB_PASSWORD=change_me_strong_password

# ── Session security ──────────────────────────────────────────
# Cairn uses password-based login (no Google/SSO required).
# These two vars are required by the auth framework regardless:

# Full public URL to this deployment — used for login redirects
NEXTAUTH_URL=http://your-server-ip:411

# Secret used to sign session JWTs — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=change_me_strong_secret

# ── GitHub (optional) ─────────────────────────────────────────
# Enables the in-app update checker under Admin → Updates
GITHUB_REPO=TemporalFixation/cairn

# ── One-click updates ─────────────────────────────────────────
# Required for the "Update Now" button in Admin → Updates.
# A secret token that only the Cairn app and the host webhook server know.
# Generate with: openssl rand -base64 32
WEBHOOK_SECRET=change_me_webhook_secret

# Port the webhook server listens on (host only, not public)
# WEBHOOK_PORT=9191

# ── Port (optional, default: 411) ─────────────────────────────
# PORT=411
