# ── Database ──────────────────────────────────────────────────
# Strong random string: openssl rand -base64 24
DB_PASSWORD=change_me_strong_password

# ── Next.js Auth ──────────────────────────────────────────────
# Full URL to your deployment (no trailing slash)
NEXTAUTH_URL=http://your-server-ip:411

# Strong random secret: openssl rand -base64 32
NEXTAUTH_SECRET=change_me_strong_secret

# ── GitHub (optional) ─────────────────────────────────────────
# Your repo for in-app update checking
GITHUB_REPO=kristoferfriers/k12-inventory

# ── Port (optional, default: 411) ─────────────────────────────
# PORT=411
